<!DOCTYPE html>
<html data-wf-domain="www.mostafaakbari.net" data-wf-site="690e0b6e2e2a0cbc45ab116e" lang="en">
<head>
  <meta charset="utf-8"/>
  <link href="https://cdn.prod.website-files.com" rel="preconnect" crossorigin="anonymous"/>
  <title>{% if entry.seo.og_title %}{{ entry.seo.og_title }}{% else %}{{ entry.title }}{% if site.site_name %} | {{ site.site_name }}{% endif %}{% endif %}</title>
  <meta content="{{ entry.seo.description or site.default_seo.description }}" name="description"/>
  <meta content="{{ entry.seo.og_title or entry.title }}" property="og:title"/>
  <meta content="{{ entry.seo.og_description or entry.seo.description or site.default_seo.description }}" property="og:description"/>
  {% if entry.seo.og_image or site.default_seo.og_image %}
  <meta content="{{ entry.seo.og_image or site.default_seo.og_image }}" property="og:image"/>
  {% endif %}
  <meta content="{{ entry.seo.og_title or entry.title }}" name="twitter:title"/>
  <meta content="{{ entry.seo.og_description or entry.seo.description or site.default_seo.description }}" name="twitter:description"/>
  <meta property="og:type" content="website"/>
  <meta content="summary_large_image" name="twitter:card"/>
  <meta content="width=device-width, initial-scale=1" name="viewport"/>
  <link href="https://cdn.prod.website-files.com/690e0b6e2e2a0cbc45ab116e/css/oxman25.webflow.shared.810108e95.css" rel="stylesheet" type="text/css" integrity="sha384-gQEI6VWa6WgQfDM16W5zD86Y624k0fLQ5038DtrGD/xKr1rJJInl9OFar5R1Q1KF" crossorigin="anonymous"/>
  <script src="https://use.typekit.net/kro4efx.js" type="text/javascript"></script>
  <script type="text/javascript">try{Typekit.load();}catch(e){}</script>
  <script type="text/javascript">!function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);</script>
</head>
<body class="{{ entry.body_class or 'body' }}">
  <main class="main">
    {% if entry.body_mode == 'sections' and entry.sections %}
      {% include "sections/render.njk" %}
    {% else %}
      {{ entry.main_html | safe }}
    {% endif %}
    {% if entry.show_projects_grid %}
      {% include "partials/projects-grid.njk" %}
    {% endif %}
    {% if entry.show_publications_list %}
      {% include "partials/publications-list.njk" %}
    {% endif %}
  </main>
  {% include "partials/chrome.njk" %}
  <script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=690e0b6e2e2a0cbc45ab116e" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
  <script src="https://cdn.prod.website-files.com/690e0b6e2e2a0cbc45ab116e/js/webflow.schunk.36b8fb49256177c8.js" type="text/javascript" integrity="sha384-4abIlA5/v7XaW1HMXKBgnUuhnjBYJ/Z9C1OSg4OhmVw9O3QeHJ/qJqFBERCDPv7G" crossorigin="anonymous"></script>
  <script src="https://cdn.prod.website-files.com/690e0b6e2e2a0cbc45ab116e/js/webflow.schunk.2e9859e08d1b9f9b.js" type="text/javascript" integrity="sha384-7nivjJ85pOUu07W4kOVffLUnW+FySyWBGlRbN20r9+Oa2lOI/zH8mij+lEyI+5Eu" crossorigin="anonymous"></script>
  <script src="https://cdn.prod.website-files.com/690e0b6e2e2a0cbc45ab116e/js/webflow.262b4fa7.b6a3134ef0de80b3.js" type="text/javascript" integrity="sha384-ADjpbAz+2o/nQVLG1JgAoHvhiCDkm27v6cVFJ6b2vGwgfkcKUtmYQBYQWT/fiPM/" crossorigin="anonymous"></script>
  {% include "partials/scripts.njk" %}
</body>
</html>
